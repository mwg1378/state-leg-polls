generator client {
  provider     = "prisma-client"
  output       = "../lib/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum RaceType {
  PARTISAN_PRIMARY
  NONPARTISAN_PRIMARY
  GENERAL
  NONPARTISAN_GENERAL
  RUNOFF
  SPECIAL_GENERAL
  SPECIAL_PRIMARY
  SPECIAL_RUNOFF
}

enum PartisanLean {
  D
  R
  NONPARTISAN
  UNKNOWN
}

enum SponsorType {
  CAMPAIGN
  PARTY
  INDEPENDENT_GROUP
  NEWS_MEDIA
  NONPARTISAN_PUBLIC
  UNKNOWN
}

enum Population {
  LV
  RV
  A
  UNKNOWN
}

enum SourceKind {
  RSS
  HTML
  X_HANDLE
  PRESS_RELEASE_INDEX
}

enum SourceType {
  PRESS_RELEASE
  NEWS_ARTICLE
  POLLSTER_MEMO
  CAMPAIGN_SITE
  AGGREGATOR
  WIKIPEDIA
  SOCIAL_MEDIA
  OTHER
}

enum PollStatus {
  PUBLISHED
  PENDING
  REJECTED
}

model City {
  slug       String  @id
  name       String
  stateCode  String  @db.Char(2)
  population Int
  notes      String? @db.Text
  createdAt  DateTime @default(now())
  races      Race[]

  @@unique([name, stateCode])
  @@index([stateCode])
  @@map("cities")
}

model Race {
  id            String   @id
  citySlug      String
  electionDate  DateTime @db.Date
  electionYear  Int
  raceType      RaceType
  party         String?
  isOpenSeat    Boolean  @default(false)
  // [{ name: string, party?: string, pct: number, isIncumbent?: boolean, advanced?: boolean }]
  actualResults Json?
  // Convenience denormalized fields:
  winnerName    String?
  winnerPct     Float?
  runnerUpName  String?
  runnerUpPct   Float?
  topMargin     Float?   // winnerPct - runnerUpPct
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  city          City     @relation(fields: [citySlug], references: [slug])
  polls         Poll[]

  @@unique([citySlug, electionDate, raceType, party])
  @@index([citySlug, electionYear])
  @@index([electionYear])
  @@index([raceType])
  @@map("races")
}

model Pollster {
  slug                String       @id
  name                String       @unique
  defaultPartisanLean PartisanLean @default(UNKNOWN)
  websiteUrl          String?
  notes               String?      @db.Text
  createdAt           DateTime     @default(now())
  polls               Poll[]

  @@map("pollsters")
}

model Poll {
  id               String      @id @default(cuid())
  raceId           String
  pollsterSlug     String
  sponsor          String
  sponsorType      SponsorType
  // [{ name: string, party?: string, pct: number }]
  candidates       Json
  // Convenience denormalized fields:
  topName          String
  topPct           Float
  runnerUpName     String?
  runnerUpPct      Float?
  topMargin        Float       // topPct - runnerUpPct (or 100 if uncontested-like)
  undecidedPct     Float       @default(0)
  startDate        DateTime    @db.Date
  endDate          DateTime    @db.Date
  sampleSize       Int?
  population       Population  @default(UNKNOWN)
  mode             String?
  daysToElection   Int
  methodologyNotes String?     @db.Text
  sourceUrl        String
  sourceType       SourceType
  sourceArchiveUrl String?
  status           PollStatus  @default(PUBLISHED)
  addedBy          String?
  addedAt          DateTime    @default(now())
  race             Race        @relation(fields: [raceId], references: [id])
  pollster         Pollster    @relation(fields: [pollsterSlug], references: [slug])

  @@index([raceId])
  @@index([pollsterSlug])
  @@index([endDate])
  @@index([status])
  @@map("polls")
}

model Source {
  id            String     @id @default(cuid())
  url           String     @unique
  label         String
  kind          SourceKind
  notes         String?
  isActive      Boolean    @default(true)
  lastScannedAt DateTime?
  createdAt     DateTime   @default(now())

  @@index([isActive])
  @@map("sources")
}
